    "pg": "^8.11.5",
    "ioredis": "^5.3.2",
    "kafkajs": "^2.2.4",
    "uuid": "^9.0.1",
    "ulid": "^2.3.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/pg": "^8.11.6",
    "@types/uuid": "^9.0.8",
    "@types/node": "^20.12.12",
    "typescript": "^5.4.5",
    "ts-node-dev": "^2.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
